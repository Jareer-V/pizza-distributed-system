{
  "name": "pizza-distributed-system",
  "version": "1.0.0",
  "description": "Highly scalable fault-tolerant distributed e-commerce system for a pizza & fast-food delivery chain",
  "scripts": {
    "build": "tsc",
    "gateway": "ts-node src/gateway/apiGateway.ts",
    "inventory-grpc": "ts-node src/inventory/grpcServer.ts",
    "loadbalancer": "ts-node src/loadbalancer/leastConnections.ts",
    "billing": "ts-node src/billing/paymentService.ts",
    "shards": "ts-node src/database/shardRouter.ts",
    "start": "concurrently \"npm run gateway\" \"npm run inventory-grpc\" \"npm run loadbalancer\""
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.0",
    "uuid": "^9.0.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7"
  }
}